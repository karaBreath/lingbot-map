# LingBot-Map Plus — copy to .env and adjust. No secrets here; keep it that way.
LBP_PORT=8500
LBP_MODEL_PATH=weights/lingbot-map.pt
LBP_SCANS_DIR=scans
LBP_UPLOAD_DIR=uploads
LBP_DEFAULT_BACKEND=directml
# where "บันทึกลงเครื่อง" copies finished scans (default ~/Documents/LingBot-Scans)
LBP_EXPORT_DIR=
